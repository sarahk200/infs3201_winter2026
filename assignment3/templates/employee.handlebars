<style>
    .morning {
        background-color: yellow;
    }
</style>

<h1>Employee Details</h1>

<p>Name: {{employee.name}}</p>
<p>Phone: {{employee.phone}}</p>
<a href="/edit/{{employee.employeeId}}">Edit Details</a>

<h2>Shifts</h2>
<table>
    <tr>
        <th>Date</th>
        <th>Start Time</th>
        <th>End Time</th>
    </tr>
    {{#each shifts}}
    <tr>
        <td>{{this.date}}</td>
        <td {{#if this.isMorning}}class="morning"{{/if}}>{{this.startTime}}</td>
        <td>{{this.endTime}}</td>
    </tr>
    {{/each}}
</table>
